# Copy to .env and fill in real values. .env is gitignored.
# Secrets moved out of app/config/config.php (commit history still contains the
# old values — rotate every key below and scrub history before going live).

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_SECRET=

# Facebook Login — https://developers.facebook.com
FACEBOOK_APP_SECRET=

# Google Gemini API
GEMINI_API_KEY=

# Cron auth — generate a strong random token, e.g. `openssl rand -hex 24`
CRON_TOKEN=
